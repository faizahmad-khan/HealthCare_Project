{
  "version": 2,
  "builds": [
    {
      "src": "api/asgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.11",
        "maxLambdaSize": "15mb",
        "installCommand": "python -m pip install --upgrade pip && python -m pip install --break-system-packages -r requirements.txt",
        "buildCommand": "python manage.py collectstatic --noinput"
      }
    },
    {
      "src": "build_files.sh",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "staticfiles"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/asgi.py"
    }
  ]
}
